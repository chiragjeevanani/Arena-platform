PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/arenacrmtest?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# Cloudinary (admin image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Mock payment webhook (Phase 9); required in production if webhook route is enabled
MOCK_PAYMENT_WEBHOOK_SECRET=

# Phase 11 — optional auth tuning
# AUTH_RATE_LIMIT_MAX=100
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# REFRESH_TOKEN_TTL_MS=2592000000
# Never in production: PASSWORD_RESET_RETURN_TOKEN (returns reset token in JSON for tests only)

# Dev-only: accept POST /api/auth/verify-otp with code DEV_OTP_CODE (default 1234). Never enable in production.
# DEV_OTP_ENABLED=true
# DEV_OTP_CODE=1234

# Set to "false" to block POST /api/auth/coach-register (coach self-signup)
# ALLOW_COACH_SELF_REGISTER=false

# SMTP Email (for registration verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="Arena CRM <your-email@gmail.com>"
FRONTEND_URL=http://localhost:5173

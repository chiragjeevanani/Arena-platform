# Backend base URL (no trailing slash). Leave unset to use mock-only auth/arenas.
VITE_API_URL=http://localhost:5000

# Backend CORS: set CORS_ORIGIN to this same origin (e.g. http://localhost:5173) so the browser
# can send cookies/Authorization to the API. Use true only for quick local hacks.

# Optional: same value as backend MOCK_PAYMENT_WEBHOOK_SECRET — enables mock card/UPI wallet top-up
# (POST /api/me/payments/intent + webhook) in Wallet and on /payment when paymentPurpose=top_up.
# VITE_MOCK_PAYMENT_WEBHOOK_SECRET=your-dev-secret
